# ─────────────────────────────────────────────────────────────
# Pasadena AI Institute — environment variables
# Copy this file to `.env.local` and fill in real values.
# The site runs fully WITHOUT any of these (graceful fallbacks):
#   • Interest form  → writes leads to /data/leads.json + server log
#   • Stripe button  → shows a "Reserve by application" fallback state
# ─────────────────────────────────────────────────────────────

# Public site URL (used for absolute links, OG tags, Stripe redirects).
# In local dev you can leave this unset (defaults to http://localhost:3000).
# In production set to your real domain, e.g. https://pasadenaaiinstitute.com
NEXT_PUBLIC_SITE_URL=

# ── Stripe (paid registration) ──────────────────────────────
# Secret key from https://dashboard.stripe.com/apikeys
# Use a test key (sk_test_...) until you're ready to go live (sk_live_...).
# No dashboard product needed — price is created inline at $995.
STRIPE_SECRET_KEY=

# ── Resend (interest-form email notifications) ──────────────
# API key from https://resend.com/api-keys
# When set, each interest-form submission emails you a lead notification.
RESEND_API_KEY=
# Where lead notifications are sent (your inbox):
LEAD_NOTIFY_EMAIL=
# Verified "from" address for Resend (e.g. hello@pasadenaaiinstitute.com).
# Falls back to onboarding@resend.dev if unset (Resend test sender).
RESEND_FROM_EMAIL=
